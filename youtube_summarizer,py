import os
import requests
from flask import Flask, request, jsonify
import yt_dlp
import google.generativeai as genai

app = Flask(__name__)

# [설정] 내 API 키 및 텔레그램 정보 입력
GEMINI_API_KEY = "YOUR_GEMINI_API_KEY"
TELEGRAM_TOKEN = "YOUR_TELEGRAM_BOT_TOKEN"
TELEGRAM_CHAT_ID = "YOUR_TELEGRAM_CHAT_ID"
genai.configure(api_key=GEMINI_API_KEY)

# 쿠키 파일 경로 (핸드폰 다운로드 폴더 기준)
COOKIE_PATH = "/sdcard/Download/cookies.txt"

def send_telegram(text):
    url = f"https://api.telegram.org/bot{TELEGRAM_TOKEN}/sendMessage"
    requests.post(url, json={"chat_id": TELEGRAM_CHAT_ID, "text": text})

@app.route('/webhook', methods=['POST'])
def handle_webhook():
    data = request.json
    video_url = data.get("url")
    
    if not video_url:
        return jsonify({"status": "fail"}), 400
        
    send_telegram("📱 핸드폰에서 웹훅 신호를 수신했습니다! 요약을 시작합니다...")
    
    ydl_opts = {
        'cookiefile': COOKIE_PATH, 
        'skip_download': True, 
        'writesubtitles': True, 
        'writeautomaticsub': True, 
        'subtitlesformat': 'srt', 
        'outtmpl': 'temp_trans'
    }
    
    try:
        with yt_dlp.YoutubeDL(ydl_opts) as ydl:
            ydl.download([video_url])
            
        srt_path = [f for f in os.listdir('.') if f.startswith('temp_trans') and f.endswith('.srt')][0]
        
        with open(srt_path, 'r', encoding='utf-8') as f:
            transcript = f.read()
            
        # Gemini 1.5 Flash 요약
        model = genai.GenerativeModel('gemini-1.5-flash')
        prompt = f"아래 유튜브 자막을 보고 핵심 키워드 5개와 3줄 요약을 작성해줘:\n\n{transcript}"
        response = model.generate_content(prompt)
        
        send_telegram(f"✨ 핸드폰 요약 완료!\n\n{response.text}")
        os.remove(srt_path)
        return jsonify({"status": "success"})
        
    except Exception as e:
        send_telegram(f"❌ 에러 발생: {e}")
        return jsonify({"status": "error", "message": str(e)}), 500

if __name__ == '__main__':
    # 핸드폰 로컬 포트 5000번으로 대기
    app.run(host='0.0.0.0', port=5000)